# Lock registry to official source
registry=https://registry.npmjs.org/

# Block malicious package installation lifecycle scripts
ignore-scripts=true

# Quarantine brand-new packages (mitigates zero-day supply chain attacks)
min-release-age=1

# Always require strict cryptographic SSL connections
strict-ssl=true

# Ensure audit scans run automatically during local installations
audit=true

# Use exact versions (no ^ or ~)
save-exact=true

# Require lockfile to exist
package-lock=true